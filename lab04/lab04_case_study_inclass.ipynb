    "   \"id\": \"76f50c6c\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"sns.FacetGrid(train, hue=\\\"churn\\\", height=7).map(sns.histplot, \\\"number_customer_service_calls\\\").add_legend();\\n\",\n",
    "    \"plt.title(\\\"Churn rate VS number_customer_service_calls\\\");\\n\",\n",
    "    \"plt.show();\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"7d981cac\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Высокий отток наблюдается при \\\"The number of customer service calls\\\" = 1 \\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"1b126d98\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Анализ выбросов\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"d210059c\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"## Числовые характеристики ##:\\n\",\n",
    "    \"# был использован seaborn, т.к. он дает лучшую визуализацию, чем pandas :\\n\",\n",
    "    \"\\n\",\n",
    "    \"for feature in numerical_variables:\\n\",\n",
    "    \"    sns.boxplot(x=\\\"churn\\\", y=feature, data=train);\\n\",\n",
    "    \"    plt.title(feature);\\n\",\n",
    "    \"    plt.show();\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"b7cff6fc\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"Из приведенного выше ясно, что каждый признак содержит выбросы, нам нужно эти выбросы удалить\\n\",\n",
    "    \" \"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"f7e96d19\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Заменяем выбросы их медианой и сохраняем их в новом датафрейме:-\\n\",\n",
    "    \"def eliminate_outliers(df, labels):\\n\",\n",
    "    \"    for feature in labels:\\n\",\n",
    "    \"        quantile1=df[feature].quantile(0.25)\\n\",\n",
    "    \"        quantile2=df[feature].quantile(0.75)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        iqr=quantile2 - quantile1\\n\",\n",
    "    \"        upper_bound=quantile2 + 1.5*iqr\\n\",\n",
    "    \"        lower_bound=quantile1 - 1.5*iqr\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        df[feature]=df[feature].mask(df[feature]<lower_bound, df[feature].median(), axis=0)\\n\",\n",
    "    \"        df[feature]=df[feature].mask(df[feature]>upper_bound, df[feature].median(), axis=0)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"    return df\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_eliminate_outliers=eliminate_outliers(train, numerical_variables)\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"f3e4950a\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"#графики \\\"Ящик с усами\\\" после удаления выбросов\\n\",\n",
    "    \"\\n\",\n",
    "    \"for feature in numerical_variables:\\n\",\n",
    "    \"    sns.boxplot(x=\\\"churn\\\", y=feature, data=train_eliminate_outliers)\\n\",\n",
    "    \"    plt.title(feature)\\n\",\n",
    "    \"    plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"400792fb\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"#### Обработка категориальных признаков ####\\n\",\n",
    "    \"\\n\",\n",
    "    \"# # функция unique() используется для нахождения количества различных значений в столбце:\\n\",\n",
    "    \"train_eliminate_outliers[\\\"state\\\"].nunique()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"d57847ae\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Из приведенного выше видно, что признак state имеет 51 различное значение.\\n\",\n",
    "    \" \\n\",\n",
    "    \" # Таким образом, если реализовать кодировщик One Hot Encoder для признака state, то он создает 51 различный признак, и есть угроза\\n\",\n",
    "    \" # переобучения, т.е. категориальные данные могут представлять серьезную проблему, если они имеют слишком много уникальных\\n\",\n",
    "    \" # значений.\\n\",\n",
    "    \" \\n\",\n",
    "    \" # Поэтому для преодоления этой проблемы используется кодировщик Hash Encoder.\\n\",\n",
    "    \"  # (https://www.analyticsvidhya.com/blog/2020/08/types-of-categorical-data-encoding/)\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"0819eb00\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"hash_object=ce.HashingEncoder(cols=\\\"state\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_hash=hash_object.fit_transform(train_eliminate_outliers);\\n\",\n",
    "    \"test_hash=hash_object.fit_transform(test);\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_hash.head() # \\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"6cf01474\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"#Замена \\\"No\\\" на 0 и \\\"Yes\\\" на 1 для значений категориальных признаков:\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_hash.international_plan.replace([\\\"no\\\", \\\"yes\\\"], [0, 1], inplace=True);\\n\",\n",
    "    \"train_hash.voice_mail_plan.replace([\\\"no\\\", \\\"yes\\\"], [0, 1], inplace=True);\\n\",\n",
    "    \"train_hash.churn.replace([\\\"no\\\", \\\"yes\\\"], [0, 1], inplace=True);\\n\",\n",
    "    \"\\n\",\n",
    "    \"test_hash.international_plan.replace([\\\"no\\\", \\\"yes\\\"], [0, 1], inplace=True);\\n\",\n",
    "    \"test_hash.voice_mail_plan.replace([\\\"no\\\", \\\"yes\\\"], [0, 1], inplace=True);\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_hash.head();\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"6859499c\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(train_hash[\\\"churn\\\"])\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"cbbd0ea0\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"## признак area_code имеет тип \\\"Object\\\",поэтому его надо конвертировать в \\\"Numerical\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_hash=pd.get_dummies(train_hash, columns=[\\\"area_code\\\"]);\\n\",\n",
    "    \"train_hash.info();\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"810a63bb\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"test_hash=pd.get_dummies(test_hash, columns=[\\\"area_code\\\"]);\\n\",\n",
    "    \"test_hash.info();\\n\",\n",
    "    \"# Признак area_code был преобразован в целочисленный тип из object type для тестовых данных.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"8ad4717e\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Теперь обработаем набор данных с несбалансированными классами\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c8d3d4b4\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"sns.countplot(x=\\\"churn\\\", data=train_hash, hue=\\\"churn\\\");\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"# 0 -> No Churn, 1 -> Churn\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"dcc6da7f\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"x=train_hash.drop(\\\"churn\\\", axis=1).values\\n\",\n",
    "    \"y=train_hash.churn.values\\n\",\n",
    "    \"\\n\",\n",
    "    \"x_train, x_test, y_train, y_test= train_test_split(x, y, test_size=0.3, random_state=0);\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"8ec59f03\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"y_train\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"e7e7f2ae\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"Исходный размер класса 0 {}\\\".format(sum(y_train==0)));\\n\",\n",
    "    \"print(\\\"Исходный размер класса 1 {}\\\".format(sum(y_train==1)));\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"3fab1db2\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"## Увеличиваем размер выборки меньшего класса, т.е. класса 1 -> Применяется только к обучающему набору ##\\n\",\n",
    "    \" # Synthetic Minority Oversampling Technique (SMOTE) #\\n\",\n",
    "    \"# https://machinelearningmastery.com/smote-oversampling-for-imbalanced-classification/\\n\",\n",
    "    \"\\n\",\n",
    "    \"sm=SMOTE(sampling_strategy=1);\\n\",\n",
    "    \"x_train_smote, y_train_smote=sm.fit_resample(x_train, y_train);\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"После увеличения размера выборки класса 0 {}\\\".format(sum(y_train_smote==0))); # class 0\\n\",\n",
    "    \"print(\\\"После увеличения размера выборки класса 1 {}\\\".format(sum(y_train_smote==1))); # class 1\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"2241f87b\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Масштабируем датасет \\n\",\n",
    "    \"\\n\",\n",
    "    \"scaler=MinMaxScaler();\\n\",\n",
    "    \"x_train_smote_scale=scaler.fit_transform(x_train_smote);\\n\",\n",
    "    \"x_test_scale=scaler.fit_transform(x_test);\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"Классическое Машинное обучение\"\n",
    "   ],\n",
    "   \"id\": \"5128b3aacda68e81\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"f0fb3893\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"#Случайный лес - RandomForest Classifier #\\n\",\n",
    "    \"rfc=RandomForestClassifier(n_jobs=-1);\\n\",\n",
    "    \"rfc.fit(x_train_smote_scale, y_train_smote);\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(accuracy_score(y_test, rfc.predict(x_test_scale)));\\n\",\n",
    "    \"# 91.5% \\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"a6e2bc51\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"test=rfc.predict(x_test_scale);\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"298d1a50\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(classification_report(y_test, test));\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"b67158c2\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"Из приведенного выше видно, что значение точности для 2-го набора данных намного лучше, чем для 1-го набора данных.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"a4322819\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Нейронная сеть\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"0478d90b\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model=Sequential()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# написать свою архитектуру и обучить сеть\\n\",\n",
    "    \"\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"e7a7b31f\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"test = [round(x[0]) for x in model.predict(x_test_scale)];\\n\",\n",
    "    \"print(accuracy_score(y_test, test));\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"ac5788b7\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \" ## Задание 2.\\n\",\n",
    "    \" Провести анализ влияния гиперпараметров на качество модели.\\n\",\n",
    "    \" \\n\",\n",
    "    \" 1. Кол-во эпох \\n\",\n",
    "    \" 2. Размер партии (батча)\\n\",\n",
    "    \" 3. Разные методы инициализации весов (напр., HeNormal)\\n\",\n",
    "    \" 4. Изменить архитектуру. Добиться качества, лучше RandomForest\\n\",\n",
    "    \"\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"d1816693\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Кривые AUC (и) ROC:-\\n\",\n",
    "    \"test_fpr, test_tpr, test_thresholds = roc_curve(y_test, test);\\n\",\n",
    "    \"test_roc_auc=auc(test_fpr, test_tpr);\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(7,5), dpi=80);\\n\",\n",
    "    \"plt.plot(test_fpr, test_tpr, color=\\\"red\\\",label='ROC кривая на train (area = %0.4f)' % test_roc_auc);\\n\",\n",
    "    \"plt.plot([0, 1], [0, 1], color='gray', lw=1, linestyle='--')\\n\",\n",
    "    \"plt.xlim([0.0, 1.0]);\\n\",\n",
    "    \"plt.ylim([0.0, 1.0]);\\n\",\n",
    "    \"plt.xlabel(\\\"False Positive Rate (FPR)\\\", fontsize=14);\\n\",\n",
    "    \"plt.ylabel(\\\"True Positive Rate (TPR)\\\", fontsize=14);\\n\",\n",
    "    \"plt.title(\\\"ROC кривая\\\", fontsize=16);\\n\",\n",
    "    \"plt.show();\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"08c12152\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
