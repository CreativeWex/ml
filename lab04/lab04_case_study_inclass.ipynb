    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Нейронная сеть\\n\",\n",
    "    \"## Задание 1. \\n\",\n",
    "    \"Построить нейросетевую модель, обучить, оценить качество модели.\\n\",\n",
    "    \"\\n\",\n",
    "    \"В этом задании необходимо использовать **Sequential** API для Tensorflow и Pytorch\"\n",
    "   ],\n",
    "   \"id\": \"2d6d795bdffb4a78\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"c17b1715\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"1.Tensorflow\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"83b7359f\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-07T13:22:09.551937Z\",\n",
    "     \"start_time\": \"2026-03-07T13:22:09.525191Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Пример построения модели с помощью `Sequential` API \\n\",\n",
    "    \"model = tf.keras.models.Sequential()\\n\",\n",
    "    \"model.add(tf.keras.Input(shape=(16,)))\\n\",\n",
    "    \"# Input_shape тензор (batch_size, input_dim)\\n\",\n",
    "    \"model.add(tf.keras.layers.Dense(32, activation='relu'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Модель ждет на вход тензор (None, 16)\\n\",\n",
    "    \"# а на выходе будет (None, 32).\\n\",\n",
    "    \"# После первого слоя не надо указывать входы для последующих слоев\\n\",\n",
    "    \"model.add(tf.keras.layers.Dense(32))\\n\",\n",
    "    \"model.output_shape\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"(None, 32)\"\n",
    "      ]\n",
    "     },\n",
    "     \"execution_count\": 30,\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"execute_result\"\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 30\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"8a3184fe\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Постройте простую ИНС - MLP (Keras Tensorflow):\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model=Sequential()\\n\",\n",
    "    \"# Архитектура сети\\n\",\n",
    "    \"#первым аргументом у Dense() идет кол-во выходных нейронов слоя\\n\",\n",
    "    \"units = 26\\n\",\n",
    "    \"model.add(Dense(units, input_dim = X_train.shape[1], activation = 'relu', kernel_initializer = tf.keras.initializers.HeNormal()))\\n\",\n",
    "    \"model.add(Dense(8,activation = 'relu', kernel_initializer = tf.keras.initializers.HeNormal()))\\n\",\n",
    "    \"model.add(Dense(8,activation = 'relu', kernel_initializer = tf.keras.initializers.HeNormal()))\\n\",\n",
    "    \"model.add(Dense(1,activation = 'sigmoid', kernel_initializer = tf.keras.initializers.HeNormal()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Создаем модель\\n\",\n",
    "    \"model.compile(optimizer='sgd', loss = \\\"binary_crossentropy\\\", metrics = [\\\"accuracy\\\"])\\n\",\n",
    "    \"\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"0a8fea86\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Обучение сети - метод fit\\n\",\n",
    "    \"model.fit(X_train, y_train, epochs = 100)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# прямой проход сети - метод predict\\n\",\n",
    "    \"test = [round(x[0]) for x in model.predict(X_test)];\\n\",\n",
    "    \"print(accuracy_score(y_test, test)); #  accuracy на train\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"ba03ceca\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(classification_report(y_test, test));\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"4aa86d56\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"Из приведенного выше видно, что модель не очень хорошо работает для класса 1, т.е. для случая, когда клиенты уходят от\\n\",\n",
    "    \"компании. Чтобы преодолеть эту проблему,  будем использовать метод SMOTE, но уже на 2-м наборе данных.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"6daeeac8\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Матрица ошибок - Confusion Matrix:\\n\",\n",
    "    \"\\n\",\n",
    "    \"cm=tf.math.confusion_matrix(labels=y_test, predictions=test);\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(10,7));\\n\",\n",
    "    \"sns.heatmap(cm, annot=True, fmt=\\\"d\\\");\\n\",\n",
    "    \"plt.xlabel(\\\"Предсказание модели\\\");\\n\",\n",
    "    \"plt.ylabel(\\\"Истинные значения\\\");\"\n",
    "   ]\n",
    "  },\n",
