    "   \"source\": [\n",
    "    \"### К- ближ.соседей - KNN ###\\n\",\n",
    "    \"from sklearn.neighbors import KNeighborsClassifier\\n\",\n",
    "    \"knn=KNeighborsClassifier(n_neighbors=3 , n_jobs=-1);\\n\",\n",
