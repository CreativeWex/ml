    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# # Импорт наборов данных для обучения и тестирования:-\\n\",\n",
    "    \"# # Датафрейм тестовых данных test предназначен только для инференса, чтобы найти целевое значение.\\n\",\n",
