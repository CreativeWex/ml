    "    \"# Оценка классификатора (тестовая выборка — новый сплит с фиксированным seed)\\n\",\n",
    "    \"from sklearn.model_selection import train_test_split\\n\",\n",
    "    \"_, X_test_cls, _, y_test_cls = train_test_split(X, Y, test_size=0.3, shuffle=True, random_state=0)\\n\",\n",
