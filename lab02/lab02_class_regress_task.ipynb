    "    \"#здесь нужна  корректировка индексов классов\\n\",\n",
    "    \"batch_size = 32\\n\",\n",
    "    \"\\n\",\n",
    "    \"for epoch in range(2000):\\n\",\n",
    "    \"    order = np.random.permutation(len(X_train))\\n\",\n",
