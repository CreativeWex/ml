    "   \"source\": [\n",
    "    \"class RegressorNet(torch.nn.Module):\\n\",\n",
    "    \"    def __init__(self, n_hidden_neurons):\\n\",\n",
    "    \"        super(RegressorNet, self).__init__()\\n\",\n",
    "    \"        self.fc1 = torch.nn.Linear(11, n_hidden_neurons)\\n\",\n",
    "    \"        self.fc2 = torch.nn.Linear(n_hidden_neurons, 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, x):\\n\",\n",
    "    \"        x = self.fc1(x)\\n\",\n",
    "    \"        x = torch.relu(x)\\n\",\n",
    "    \"        x = self.fc2(x)\\n\",\n",
    "    \"        return x\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def inference(self, x):\\n\",\n",
    "    \"        return self.forward(x).squeeze(-1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"reg_net = RegressorNet(n_hidden_neurons=32)\"\n",
    "   ]\n",
