    "    \"        loss_value.backward()\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        optimizer.step()\\n\",\n",
    "    \"        \\n\",\n",
    "    \"    if epoch % 100 == 0:\\n\",\n",
