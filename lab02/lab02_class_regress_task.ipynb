    "    }\n",
    "   },\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from random import randrange\\n\",\n",
    "    \" \\n\",\n",
    "    \"def zero_rule_algorithm_regression(train, test):\\n\",\n",
